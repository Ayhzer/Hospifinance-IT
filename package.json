{
  "name": "hospifinance-it",
  "version": "1.1.0",
  "description": "Hospifinance-IT — Tableau de bord financier générique et réutilisable pour le suivi OPEX et CAPEX d'une DSI hospitalière",
  "private": false,
  "type": "module",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "server": "node local-server.js",
    "start": "concurrently \"node local-server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8"
  },
  "keywords": [
    "dashboard",
    "finance",
    "hospital",
    "IT",
    "OPEX",
    "CAPEX",
    "budget",
    "tracking"
  ],
  "author": "Hospifinance-IT",
  "license": "MIT"
}
