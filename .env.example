# ─────────────────────────────────────────────────────────────────────────────
# Hospifinance-IT — Configuration d'environnement (exemple)
# Copiez ce fichier en .env.local et adaptez les valeurs à votre établissement.
# ─────────────────────────────────────────────────────────────────────────────

# Configuration de l'API backend (optionnel)
# Si vide ou absent : mode localStorage (recommandé pour démarrer).
# Si défini : mode API (nécessite le backend Express + MongoDB du dossier backend/).
# VITE_API_URL=http://localhost:3001/api

# Synchronisation GitHub automatique (optionnel)
# Ces variables activent la sync vers un dépôt de données privé sans configuration
# manuelle dans le navigateur. Remplacez par les valeurs de VOTRE établissement.
# VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxx     (Fine-grained PAT avec accès au repo de données)
# VITE_GITHUB_OWNER=votre-organisation
# VITE_GITHUB_REPO=hospifinance-it-data
# VITE_GITHUB_BRANCH=main
# VITE_GITHUB_DATA_PATH=data
