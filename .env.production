# Hospifinance-IT — Configuration de production
# Stockage via localStorage + synchronisation GitHub (optionnelle).
#
# Synchronisation GitHub automatique (injectée au build, p.ex. via GitHub Actions).
# Le token NE DOIT PAS être committé ici — l'injecter via un secret VITE_GITHUB_TOKEN.
# Remplacez owner/repo par ceux de VOTRE établissement.
# VITE_GITHUB_OWNER=votre-organisation
# VITE_GITHUB_REPO=hospifinance-it-data
# VITE_GITHUB_BRANCH=main
# VITE_GITHUB_DATA_PATH=data
